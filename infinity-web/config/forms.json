{
    "iwl": {
        "title": "I Would Like...",
        "fields": [
            {"name": "name", "type": "text", "label": "Alias / Name", "required": true},
            {"name": "email", "type": "email", "label": "Email Address", "required": true},
            {"name": "phone", "type": "tel", "label": "Phone (Optional)", "required": false},
            {"name": "request", "type": "textarea", "label": "What do you need?", "required": true}
        ],
        "submitText": "Send Request"
    },
    "upload": {
        "title": "Upload Script / Tool",
        "fields": [
            {"name": "title", "type": "text", "label": "Script Name", "required": true},
            {"name": "description", "type": "textarea", "label": "Description & Requirements", "required": true},
            {"name": "sponsor", "type": "select", "label": "Are you an Infinity Sponsor?", "options": ["Yes", "No"]},
            {"name": "file_data", "type": "textarea", "label": "Paste Script Content / Base64 here", "required": true}
        ],
        "submitText": "Submit for Review"
    }
}
