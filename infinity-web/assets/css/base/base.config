# CORE BASE CONFIGURATION
BOX_SIZING=border-box
BG_GRADIENT_PRIMARY=radial-gradient(circle at top, rgba(124, 58, 237, 0.18), transparent 32%)
BG_GRADIENT_SECONDARY=radial-gradient(circle at 20% 20%, rgba(34, 197, 94, 0.08), transparent 20%)
