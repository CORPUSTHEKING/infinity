export function handleDownload(itemPath, fileName = '') {
  if (!itemPath) return;

  const href = new URL(itemPath, window.location.href).href;
  const link = document.createElement('a');
  link.href = href;
  if (fileName) link.download = fileName;
  link.rel = 'noopener noreferrer';
  document.body.appendChild(link);
  link.click();
  link.remove();
}

export function bindCardActions(root, handlers = {}) {
  if (!root) return () => {};

  const onClick = (event) => {
    const expandButton = event.target.closest('[data-script-expand]');
    const actionButton = event.target.closest('[data-action]');
    const card = event.target.closest('[data-script-card]');

    if (!card) return;

    const itemId = card.getAttribute('data-script-id') || '';
    const itemPath = card.getAttribute('data-script-path') || '';

    if (expandButton) {
      card.classList.toggle('is-expanded');
      handlers.onExpand?.(itemId, card);
      return;
    }

    if (actionButton) {
      const action = actionButton.getAttribute('data-action') || '';
      handlers.onAction?.(action, itemId, card);

      if (action === 'download') {
        handlers.onDownload?.(itemPath, card);
      }
    }
  };

  root.addEventListener('click', onClick);

  return () => root.removeEventListener('click', onClick);
}
EOF_JS

