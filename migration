import { renderCategoriesView, renderSearchResultsView } from './components/categories.js';
import { getManifest, getForms, getPlatforms, getDevices, getSiteConfig, searchScripts } from './data.js';

import { renderAssistancePage } from './pages/assistance.js';
import { renderSearchPage } from './pages/search.js';
import { renderSharePage } from './pages/share.js';
import { renderUploadPage, bindUploadEvents } from './pages/upload.js';
import { renderRequestPage } from './pages/request.js';
import { renderReviewPage } from './pages/review.js';
import { renderReportPage } from './pages/report.js';
import { renderSponsorPage } from './pages/sponsor.js';
import { renderPlatformsPage } from './pages/platforms.js';
import { renderDevicesPage } from './pages/devices.js';
import { renderDisclaimerPage } from './pages/disclaimer.js';
import { renderTerminalPage } from './pages/terminal.js';
import { renderIwlPage } from './pages/iwl.js';

function setActiveLinks(hash) {
  document.querySelectorAll('.inf-bottombar a, .inf-drawer a, .inf-quickrail a').forEach((link) => {
    link.classList.remove('active');
    const href = link.getAttribute('href')?.replace('#', '') || '';
    if (href.split('?')[0] === hash) link.classList.add('active');
  });
}

export async function initRouter(ui) {
  const siteConfig = await getSiteConfig();

  async function handleRoute() {
    const rawHash = window.location.hash.replace('#', '') || 'assistance';
    const [hashPath, queryString = ''] = rawHash.split('?');
    const hash = hashPath || 'assistance';
    const params = new URLSearchParams(queryString);

    setActiveLinks(hash);

    switch (hash) {
      case 'assistance':
      case 'home':
        ui.setPageContent(renderAssistancePage());
        break;

      case 'download': {
        ui.setPageContent('<div class="inf-page"><p class="inf-loading">Loading script manifest...</p></div>');
        const manifest = await getManifest();
        ui.setPageContent(renderCategoriesView(manifest));
        break;
      }

      case 'search': {
        const query = params.get('q') || '';
        if (!query) {
          ui.setPageContent(renderSearchPage([], ''));
          break;
        }
        ui.setPageContent(`<div class="inf-page"><p class="inf-loading">Searching for "${query}"...</p></div>`);
        const results = await searchScripts(query);
        ui.setPageContent(renderSearchResultsView(results, query));
        break;
      }

      case 'upload': {
        const forms = await getForms();
        ui.setPageContent(renderUploadPage(forms.upload || {}));
        bindUploadEvents(siteConfig);
        break;
      }

      case 'share': {
        const forms = await getForms();
        ui.setPageContent(renderSharePage(forms.share || {}));
        break;
      }

      case 'request': {
        const forms = await getForms();
        ui.setPageContent(renderRequestPage(forms.request || {}));
        break;
      }

      case 'review': {
        const forms = await getForms();
        ui.setPageContent(renderReviewPage(forms.review || {}));
        break;
      }

      case 'report': {
        const forms = await getForms();
        ui.setPageContent(renderReportPage(forms.report || {}));
        break;
      }

      case 'platforms':
        ui.setPageContent(renderPlatformsPage(await getPlatforms()));
        break;

      case 'devices':
        ui.setPageContent(renderDevicesPage(await getDevices()));
        break;

      case 'sponsor':
        ui.setPageContent(renderSponsorPage());
        break;

      case 'disclaimer':
        ui.setPageContent(renderDisclaimerPage());
        break;

      case 'terminal':
        ui.setPageContent(renderTerminalPage());
        break;

      case 'iwl': {
        const forms = await getForms();
        ui.setPageContent(renderIwlPage(forms.iwl || {}));
        break;
      }

      default:
        ui.setPageContent(`
          <div class="inf-page">
            <h2>${hash.toUpperCase()}</h2>
            <p>Information regarding ${hash} is currently being updated.</p>
          </div>
        `);
        break;
    }

    window.scrollTo({ top: 0, behavior: 'smooth' });
  }

  window.addEventListener('hashchange', handleRoute);
  await handleRoute();
}
