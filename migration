cat > "$TARGET/public/infinity/js/data.js" <<'EOF_JS'
let cachedSite = null;
let cachedForms = null;
let cachedPlatforms = null;
let cachedDevices = null;
let cachedScriptTree = null;

function jsonURL(relativePath) {
  return new URL(relativePath, import.meta.url).href;
}

async function loadJSON(relativePath, fallback = null) {
  try {
    const res = await fetch(jsonURL(relativePath));
    if (!res.ok) return fallback;
    return await res.json();
  } catch {
    return fallback;
  }
}

function walkTree(nodes = [], out = []) {
  for (const node of nodes) {
    if (!node) continue;
    if (node.type === 'file') {
      out.push(node);
      continue;
    }
    if (node.type === 'directory' && Array.isArray(node.children)) {
      walkTree(node.children, out);
    }
  }
  return out;
}

function normalizePayloadPath(path = '') {
  const value = String(path || '').replace(/^\/+/, '');

  if (!value) return '';
  if (value.startsWith('infinity/payloads/')) return value;
  if (value.startsWith('assets/payloads/')) return value.replace(/^assets\/payloads\//, 'infinity/payloads/');
  if (value.startsWith('payloads/')) return `infinity/${value}`;
  return `infinity/payloads/${value.replace(/^.*?payloads\//, '')}`;
}

function normalizeNode(node) {
  if (!node || typeof node !== 'object') return node;

  if (node.type === 'file') {
    return {
      ...node,
      path: normalizePayloadPath(node.path || node.name)
    };
  }

  if (node.type === 'directory' && Array.isArray(node.children)) {
    return {
      ...node,
      children: node.children.map(normalizeNode)
    };
  }

  return node;
}

function normalizeTree(tree = []) {
  return tree.map(normalizeNode);
}

export async function getSiteConfig() {
  if (cachedSite) return cachedSite;
  cachedSite = await loadJSON('../data/site.json', {});
  return cachedSite;
}

export async function getForms() {
  if (cachedForms) return cachedForms;
  const data = await loadJSON('../data/forms.json', {});
  cachedForms = data.forms || {};
  return cachedForms;
}

export async function getPlatforms() {
  if (cachedPlatforms) return cachedPlatforms;
  const data = await loadJSON('../data/platforms.json', {});
  cachedPlatforms = data.platforms || [];
  return cachedPlatforms;
}

export async function getDevices() {
  if (cachedDevices) return cachedDevices;
  const data = await loadJSON('../data/devices.json', {});
  cachedDevices = data.devices || [];
  return cachedDevices;
}

export async function getScriptTree() {
  if (cachedScriptTree) return cachedScriptTree;
  const data = await loadJSON('../data/scripts.json', {});
  const raw = data.tree || data.categories || [];
  cachedScriptTree = normalizeTree(raw);
  return cachedScriptTree;
}

export async function getManifest() {
  return getScriptTree();
}

export async function getScripts() {
  return walkTree(await getScriptTree(), []);
}

export async function searchScripts(query = '') {
  const q = String(query).trim().toLowerCase();
  if (!q) return [];

  const scripts = await getScripts();
  return scripts.filter((item) => {
    const blob = [
      item.id,
      item.name,
      item.title,
      item.author,
      item.category,
      item.path,
      item.description,
      item.note
    ]
      .filter(Boolean)
      .join(' ')
      .toLowerCase();

    return blob.includes(q);
  });
}
EOF_JS

